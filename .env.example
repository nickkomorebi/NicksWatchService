# Database
DATABASE_URL=sqlite+aiosqlite:///./data/watchservice.db
# For Postgres: DATABASE_URL=postgresql+asyncpg://user:pass@host/db

# Security
RUN_TOKEN=generate-a-long-random-string-here

# Google Sheets
GOOGLE_SHEET_ID=1iYGwTzaBVmB01jjZbY7cxbH_jhzE1o0ExdXf9RRNduY
GOOGLE_SHEET_TAB=watches
GOOGLE_SERVICE_ACCOUNT_JSON=/app/secrets/service_account.json
# OR as inline JSON: GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

# Search APIs
SERPER_API_KEY=
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_VERIFICATION_TOKEN=generate-a-random-string-here
EBAY_DELETION_ENDPOINT_URL=https://your-tunnel-domain.com/api/ebay/marketplace-account-deletion

# LLM
ANTHROPIC_API_KEY=

# Scheduler
SCHEDULE_INTERVAL_HOURS=6

# App
APP_PORT=8000
LOG_LEVEL=INFO
